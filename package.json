{
  "name": "library-microservices",
  "version": "1.0.0",
  "description": "Microservices-based library management system",
  "private": true,
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest --passWithNoTests",
    "test:unit": "npm run test --workspaces --if-present",
    "test:all": "npm run test --workspaces --if-present",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:e2e": "jest --config jest.e2e.config.js"
  },
  "devDependencies": {
    "axios": "^1.7.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
