# Environment
NODE_ENV=development

# Service Ports
BOOKS_SERVICE_PORT=3001
USERS_SERVICE_PORT=3002
LOANS_SERVICE_PORT=3003
NOTIFICATIONS_SERVICE_PORT=3004

# Database URLs
BOOKS_DB_URL=mongodb://localhost:27017/books
USERS_DB_URL=mongodb://localhost:27017/users
LOANS_DB_URL=mongodb://localhost:27017/loans
NOTIFICATIONS_DB_URL=mongodb://localhost:27017/notifications

# Message Queue
RABBITMQ_URL=amqp://localhost:5672

# API Gateway / Load Balancer
NGINX_PORT=80

# JWT Secret (change in production)
JWT_SECRET=your_jwt_secret_key_here

# Logging
LOG_LEVEL=info
